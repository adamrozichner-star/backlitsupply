# Supabase (create NEW project at supabase.com — DO NOT reuse DPO's)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Resend (transactional email)
RESEND_API_KEY=re_your_key_here

# Stripe (payment links — no secret key needed for links, just public)
# Payment links are hardcoded in pricing page for now

# Plausible (analytics — just the domain, no key needed)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=backlitsupply.com
